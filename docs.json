{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LightSwap Partner API",
  "colors": {
    "primary": "#0C8C5E",
    "light": "#18E299",
    "dark": "#18E299"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Partner API",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "index",
              "quickstart",
              "partner-api/authentication",
              "partner-api/integration-flow",
              "partner-api/statuses-errors",
              "partner-api/limits"
            ]
          },
          {
            "group": "API reference",
            "pages": [
              "api-reference/introduction",
              "api-reference/asset",
              "api-reference/address",
              "api-reference/quote",
              "api-reference/create-swap",
              "api-reference/get-swap"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "LightSwap",
          "href": "https://lightswap.me",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Support",
          "href": "https://lightswap.me/support",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://lightswap.me/support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open LightSwap",
      "href": "https://lightswap.me"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
